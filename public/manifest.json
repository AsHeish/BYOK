{
  "manifest_version": 3,
  "name": "BYOK AI Browser Agent",
  "description": "A bring-your-own-key browser agent that can summarize, extract, and safely interact with webpages.",
  "version": "0.1.4",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "index.html",
    "default_title": "BYOK Agent"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
